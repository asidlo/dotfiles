#!/usr/bin/env bash
# Bridge WSL git to the Windows Git Credential Manager, choosing the build that
# matches the host CPU. Git for Windows installs GCM under an arch-specific dir:
#   x64   -> mingw64
#   arm64 -> clangarm64
# Detecting at runtime keeps a single gitconfig working on both x64 and arm64 WSL
# without per-machine edits. Override the install root with GIT_FOR_WINDOWS_ROOT.

progfiles="${GIT_FOR_WINDOWS_ROOT:-/mnt/c/Program Files/Git}"

# Prefer the arch-matching dir, then fall back to the other (handles unusual
# installs, e.g. an x64 Git running under arm64 WSL via emulation).
case "$(uname -m)" in
  aarch64 | arm64) archdirs="clangarm64 mingw64 mingw32" ;;
  *) archdirs="mingw64 clangarm64 mingw32" ;;
esac

for sub in $archdirs; do
  gcm="$progfiles/$sub/bin/git-credential-manager.exe"
  if [ -x "$gcm" ]; then
    exec "$gcm" "$@"
  fi
done

echo "git-credential-manager-wsl: git-credential-manager.exe not found under \"$progfiles\" (looked in: $archdirs)" >&2
echo "git-credential-manager-wsl: set GIT_FOR_WINDOWS_ROOT if Git for Windows is installed elsewhere." >&2
exit 1
